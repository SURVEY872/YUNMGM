                            const configMap = {};
                            data.forEach(setting => {
                                configMap[setting.key] = setting.value;
                            });
                            
                            const siteEnabled = configMap['site_enabled'] === 'true' || configMap['site_enabled'] === true;
                            
                            if (!siteEnabled) {
                                window.location.href = '/auth/login';
