    <script>
        function createParticles() {
            const particlesContainer = document.getElementById('particles');
            if (!particlesContainer) return;
            
            const particleCount = 50;
            
            for (let i = 0; i < particleCount; i++) {
                const particle = document.createElement('div');
                particle.className = 'particle';
                
                const size = Math.random() * 6 + 2;
                particle.style.width = `${size}px`;
                particle.style.height = `${size}px`;
                particle.style.left = `${Math.random() * 100}%`;
                
                const duration = Math.random() * 10 + 10;
                const delay = Math.random() * 5;
                particle.style.animationDuration = `${duration}s`;
                particle.style.animationDelay = `${delay}s`;
                
                particlesContainer.appendChild(particle);
            }
        }
        
        document.addEventListener('DOMContentLoaded', createParticles);
        
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });
    </script>
    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.data('homePage', () => ({
                siteConfig: {
                    site_name: '',
                    site_description: '',
                    home_banner_text: '',
                    site_keywords: '',
                    home_features: '',
                    footer_copyright: ''
                },
                
                async init() {
                    await this.loadConfig();
                },
                
                async loadConfig() {
                    try {
                        const response = await fetch('/api/settings/public');
                        if (response.ok) {
                            const data = await response.json();
                            const configMap = {};
                            data.forEach(setting => {
                                configMap[setting.key] = setting.value;
                            });
                            
                            this.siteConfig.site_name = configMap['site_name'] || 'YUNMGM';
                            this.siteConfig.site_description = configMap['site_description'] || '简单、快速、安全的节点部署解决方案';
                            this.siteConfig.home_banner_text = configMap['home_banner_text'] || 'YUNMGM 节点一键部署系统';
                            this.siteConfig.site_keywords = configMap['site_keywords'] || 'YUNMGM，节点部署，VLESS,TUIC,Trojan,Hysteria2';
                            this.siteConfig.home_features = configMap['home_features'] || '';
                            this.siteConfig.footer_copyright = configMap['footer_copyright'] || '&copy; 2024 YUNMGM. All rights reserved.';
                            
                            document.title = this.siteConfig.site_name + ' - 节点一键部署系统';
                            
                            const metaDesc = document.querySelector('meta[name="description"]');
                            if (metaDesc) {
                                metaDesc.setAttribute('content', this.siteConfig.site_description);
                            }
                            
                            const metaKeywords = document.querySelector('meta[name="keywords"]');
                            if (metaKeywords) {
                                metaKeywords.setAttribute('content', this.siteConfig.site_keywords);
                            }
                            
                            const bannerDesc = document.querySelector('[data-banner-description]');
                            if (bannerDesc && this.siteConfig.site_description) {
                                bannerDesc.innerHTML = this.siteConfig.site_description.replace(/\n/g, '<br>');
                            }
                            
                            if (this.siteConfig.home_features) {
                                try {
                                    const features = JSON.parse(this.siteConfig.home_features);
                                    this.updateFeatures(features);
                                } catch (e) {
                                    console.error('解析特性介绍失败:', e);
                                }
                            }
                        }
                    } catch (error) {
                        console.error('首页加载配置失败:', error);
                    }
                },
                
                updateFeatures(features) {
                    const featuresSection = document.querySelector('[data-features-section]');
                    if (featuresSection) {
                        featuresSection.innerHTML = features.map(feature => `
                            <div class="bg-gray-800 rounded-2xl p-6 border border-gray-700 hover:border-blue-500/50 transition-all">
                                <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center mb-4">
                                    <i class="fas fa-${feature.icon || 'bolt'} text-2xl text-white"></i>
                                </div>
                                <h3 class="text-xl font-bold text-white mb-2">${feature.title || '特性'}</h3>
                                <p class="text-gray-400 text-sm">${feature.desc || '描述'}</p>
                            </div>
                        `).join('');
                    }
                }
            }))
        })
    </script>
